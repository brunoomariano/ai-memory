# Copy to .env.local at the repo root (gitignored).
# scripts/windows/serve.ps1 loads this file automatically when present.

# Data directory (optional; default: %LOCALAPPDATA%\ai-memory on Windows)
# AI_MEMORY_DATA_DIR=C:\Users\you\.ai-memory

# --- Zero-LLM mode: leave everything below commented out ---

# LLM provider: anthropic | openai | openai-compat | gemini | cursor (fork)
# AI_MEMORY_LLM_PROVIDER=anthropic

# Cursor SDK (local Composer — fork-only; same pool as the IDE)
# Requires: cd scripts/cursor-bridge && npm install
# AI_MEMORY_LLM_PROVIDER=cursor
# CURSOR_API_KEY=
# CURSOR_MODEL=composer-2.5
# CURSOR_MODEL_FAST=false
# CURSOR_AGENT_CWD=C:\path\to\project
# CURSOR_TIMEOUT_MS=120000

# LLM (session consolidation, bootstrap)
# AI_MEMORY_LLM_PROVIDER=anthropic
# AI_MEMORY_LLM_MODEL=claude-haiku-4-5
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible (OpenRouter, Ollama, vLLM, …)
# AI_MEMORY_LLM_PROVIDER=openai-compat
# AI_MEMORY_LLM_BASE_URL=https://openrouter.ai/api/v1
# AI_MEMORY_LLM_MODEL=anthropic/claude-haiku-4.5
# LLM_API_KEY=sk-or-v1-...

# Embeddings (hybrid search; optional)
# OpenAI-compatible gateways (e.g. OpenRouter) reuse the same HTTP shape as openai-compat.
# API key: OPENAI_API_KEY or LLM_API_KEY (handy when LLM already uses OpenRouter).
# AI_MEMORY_EMBEDDING_PROVIDER=openai
# AI_MEMORY_EMBEDDING_MODEL=openai/text-embedding-3-small
# AI_MEMORY_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...   # alternative if LLM does not use OpenRouter
# AI_MEMORY_EMBEDDING_DIM=1536

# Embeddings via OpenAI directly (no aggregator)
# AI_MEMORY_EMBEDDING_PROVIDER=openai
# AI_MEMORY_EMBEDDING_MODEL=text-embedding-3-small
# AI_MEMORY_EMBEDDING_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# Google Gemini embeddings (https://ai.google.dev/gemini-api/docs/embeddings)
# AI_MEMORY_EMBEDDING_PROVIDER=google
# AI_MEMORY_EMBEDDING_MODEL=gemini-embedding-001
# AI_MEMORY_EMBEDDING_DIM=768
# GEMINI_API_KEY=
# GOOGLE_API_KEY=   # accepted alias

# Auth (only when exposing beyond loopback)
# AI_MEMORY_AUTH_TOKEN=
